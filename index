<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Shield by Brockway — Institutional risk governance for MT5. SOD floors, ratchet protection, session sweeps. $99/month. Any broker. Any strategy.">
<title>Shield — Institutional Risk Infrastructure for MT5 | Brockway</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&family=Libre+Franklin:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ================================================================
   SHIELD — BROCKWAY RISK INFRASTRUCTURE
   Nasdaq institutional authority + Bloomberg terminal DNA.
   The page that closes.
================================================================ */
:root {
  --bg:       #050607;
  --surface:  #0A0B0D;
  --panel:    #0E0F11;
  --elevated: #131416;
  --card:     #161719;
  --border:   #1C1D20;
  --border-h: #27282C;
  --dim:      #363840;
  --muted:    #50525A;
  --sub:      #72747E;
  --body:     #9497A3;
  --text:     #B8BBC6;
  --bright:   #D4D7E0;
  --white:    #F0F1F5;

  /* Institutional blue — Nasdaq trust signal */
  --blue:     #0094FF;
  --blue-hi:  #40AFFF;
  --blue-30:  rgba(0,148,255,0.30);
  --blue-20:  rgba(0,148,255,0.20);
  --blue-10:  rgba(0,148,255,0.10);
  --blue-05:  rgba(0,148,255,0.05);
  --blue-03:  rgba(0,148,255,0.03);

  /* Signal palette — surgical use only */
  --green:    #00D26A;
  --green-20: rgba(0,210,106,0.20);
  --green-10: rgba(0,210,106,0.10);
  --green-05: rgba(0,210,106,0.05);
  --amber:    #FF9500;
  --amber-20: rgba(255,149,0,0.20);
  --amber-10: rgba(255,149,0,0.10);
  --red:      #FF3B3B;
  --red-20:   rgba(255,59,59,0.20);
  --red-10:   rgba(255,59,59,0.10);
  --cyan:     #00D4FF;

  --mono:  'IBM Plex Mono', monospace;
  --serif: 'Instrument Serif', Georgia, serif;
  --sans:  'Libre Franklin', system-ui, sans-serif;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { font-size: 16px; -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: var(--sans); overflow-x: hidden; }
::selection { background: var(--blue-20); color: var(--white); }

/* Scanline texture */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 99999;
  pointer-events: none;
  background: repeating-linear-gradient(to bottom, transparent 0px, transparent 3px, rgba(0,0,0,0.015) 3px, rgba(0,0,0,0.015) 6px);
}

/* ── NAV ── */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  height: 56px;
  background: rgba(5,6,7,0.88);
  backdrop-filter: blur(24px) saturate(1.3);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 48px;
}

.nav-left { display: flex; align-items: center; gap: 20px; }
.nav-mark {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}
.nav-logo {
  width: 28px; height: 28px;
  border-radius: 50%;
  border: 1px solid rgba(145,206,79,0.3);
  object-fit: cover;
  box-shadow: 0 0 12px rgba(145,206,79,0.15);
}
.nav-mark-text {
  font-family: var(--sans);
  font-size: 16px;
  font-weight: 800;
  color: var(--white);
  letter-spacing: 4px;
  text-transform: uppercase;
}
.nav-sep { width: 1px; height: 18px; background: var(--border-h); }
.nav-corp {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--muted);
  letter-spacing: 1px;
}

.nav-right { display: flex; align-items: center; gap: 32px; }
.nav-link {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--sub);
  text-decoration: none;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  transition: color 0.2s;
}
.nav-link:hover { color: var(--white); }

.nav-cta {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 8px 22px;
  background: var(--blue);
  color: var(--white);
  text-decoration: none;
  transition: all 0.25s;
}
.nav-cta:hover { background: var(--blue-hi); box-shadow: 0 0 24px var(--blue-20); }

@media (max-width: 768px) {
  .nav { padding: 0 20px; }
  .nav-link, .nav-sep, .nav-corp { display: none; }
}

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 56px 0 0;
  overflow: hidden;
}

/* Cinematic gradient field */
.hero-field {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 20% 80%, rgba(0,148,255,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 20%, rgba(0,148,255,0.04) 0%, transparent 50%);
}

/* Grid overlay */
.hero-grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,148,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,148,255,0.03) 1px, transparent 1px);
  background-size: 100px 100px;
  mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
}

/* Datum line */
.hero-datum {
  position: absolute;
  left: 0; right: 0;
  top: 52%;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--blue-20) 25%, var(--blue) 50%, var(--blue-20) 75%, transparent);
  opacity: 0;
  animation: datumIn 2s 1s ease forwards;
}
@keyframes datumIn { to { opacity: 0.6; } }

/* Terminal ribbon - top */
.hero-ribbon {
  position: absolute;
  top: 56px; left: 0; right: 0;
  height: 32px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  overflow: hidden;
}
.ribbon-track {
  display: flex;
  align-items: center;
  gap: 0;
  animation: ribbonScroll 50s linear infinite;
  white-space: nowrap;
  width: max-content;
}
@keyframes ribbonScroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.ribbon-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 28px;
  height: 32px;
  border-right: 1px solid var(--border);
  font-family: var(--mono);
  font-size: 10px;
}
.ri-sym { color: var(--white); font-weight: 600; letter-spacing: 1px; }
.ri-val { color: var(--blue); }
.ri-chg { font-size: 9px; }
.ri-chg.up { color: var(--green); }
.ri-chg.dn { color: var(--red); }

/* Hero content */
.hero-content {
  position: relative;
  z-index: 2;
  padding: 0 48px;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

.hero-kicker {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 36px;
  display: flex;
  align-items: center;
  gap: 14px;
  opacity: 0;
  animation: fadeUp 0.8s 0.5s ease forwards;
}
.hero-kicker::before {
  content: '';
  width: 32px; height: 2px;
  background: var(--blue);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-h1 {
  font-family: var(--sans);
  font-weight: 900;
  font-size: clamp(48px, 8vw, 120px);
  line-height: 0.9;
  letter-spacing: -0.035em;
  color: var(--white);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.8s 0.6s ease forwards;
}
.hero-h1 .serif {
  font-family: var(--serif);
  font-weight: 400;
  font-style: italic;
  color: var(--blue);
  letter-spacing: -0.01em;
}

.hero-h1-sub {
  font-family: var(--sans);
  font-weight: 200;
  font-size: clamp(22px, 3.5vw, 52px);
  line-height: 1.05;
  letter-spacing: -0.02em;
  color: var(--sub);
  margin-bottom: 48px;
  opacity: 0;
  animation: fadeUp 0.8s 0.7s ease forwards;
}

.hero-body {
  max-width: 580px;
  font-size: 16px;
  line-height: 1.8;
  color: var(--body);
  font-weight: 300;
  margin-bottom: 44px;
  opacity: 0;
  animation: fadeUp 0.8s 0.8s ease forwards;
}
.hero-body strong { color: var(--white); font-weight: 500; }

.hero-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.8s 0.9s ease forwards;
}

.btn-main {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 40px;
  background: var(--blue);
  color: var(--white);
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.btn-main::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  transform: translateX(-100%);
  transition: transform 0.5s;
}
.btn-main:hover::after { transform: translateX(100%); }
.btn-main:hover {
  background: var(--blue-hi);
  box-shadow: 0 4px 40px var(--blue-20);
  transform: translateY(-1px);
}

.btn-ghost {
  display: inline-flex;
  align-items: center;
  padding: 16px 40px;
  border: 1px solid var(--border-h);
  color: var(--sub);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s;
}
.btn-ghost:hover { border-color: var(--blue-20); color: var(--blue); }

/* Hero bottom strip — live system data */
.hero-strip {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  border-top: 1px solid var(--border);
  background: rgba(5,6,7,0.6);
  backdrop-filter: blur(12px);
  opacity: 0;
  animation: fadeUp 0.8s 1.1s ease forwards;
}
.hs-cell {
  padding: 20px 32px;
  border-right: 1px solid var(--border);
  transition: background 0.3s;
}
.hs-cell:last-child { border-right: none; }
.hs-cell:hover { background: var(--blue-03); }
.hs-label {
  font-family: var(--mono);
  font-size: 8px;
  color: var(--muted);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.hs-val {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 22px;
  color: var(--white);
  letter-spacing: -0.5px;
}
.hs-val .u { font-size: 11px; font-weight: 300; color: var(--muted); margin-left: 3px; }
.hs-val .sig { color: var(--blue); }
.hs-val .grn { color: var(--green); }

@media (max-width: 1100px) {
  .hero-strip { grid-template-columns: repeat(3, 1fr); }
  .hs-cell:nth-child(n+4) { display: none; }
}
@media (max-width: 640px) {
  .hero-strip { grid-template-columns: repeat(2, 1fr); }
  .hs-cell:nth-child(n+3) { display: none; }
  .hero-content { padding: 0 20px; }
  .hero-ribbon { display: none; }
}

/* ── INSTITUTIONAL STATEMENT (Nasdaq-style) ── */
.statement {
  padding: 140px 48px;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.statement::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 50% 60% at 50% 40%, var(--blue-05), transparent);
}
.st-inner {
  position: relative;
  z-index: 1;
  max-width: 900px;
  margin: 0 auto;
}
.st-tag {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 6px;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 32px;
}
.st-headline {
  font-family: var(--serif);
  font-size: clamp(32px, 5vw, 64px);
  line-height: 1.1;
  color: var(--white);
  margin-bottom: 24px;
  letter-spacing: -0.01em;
}
.st-headline em { color: var(--blue); font-style: italic; }
.st-body {
  font-size: 17px;
  line-height: 1.85;
  color: var(--body);
  font-weight: 300;
  max-width: 640px;
  margin: 0 auto;
}
.st-body strong { color: var(--white); font-weight: 500; }

@media (max-width: 768px) { .statement { padding: 80px 20px; } }

/* ── SECTION DIVIDER ── */
.divider {
  height: 1px;
  background: var(--border);
  position: relative;
}
.divider::after {
  content: '';
  position: absolute;
  left: 50%; top: -1px;
  transform: translateX(-50%);
  width: 120px;
  height: 3px;
  background: var(--blue);
  opacity: 0.4;
}

/* ── PROBLEM / RESPONSE — SPLIT PANEL ── */
.split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 600px;
}
@media (max-width: 960px) { .split { grid-template-columns: 1fr; } }

.split-panel {
  padding: 64px 56px;
  position: relative;
}
.split-panel.left { border-right: 1px solid var(--border); }

.sp-tag {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--mono);
  font-size: 8px;
  font-weight: 600;
  letter-spacing: 4px;
  text-transform: uppercase;
  padding: 4px 14px;
  margin-bottom: 32px;
  border: 1px solid;
}
.sp-tag.red { color: var(--red); border-color: var(--red-20); background: var(--red-10); }
.sp-tag.blue { color: var(--blue); border-color: var(--blue-20); background: var(--blue-05); }
.sp-tag.green { color: var(--green); border-color: var(--green-20); background: var(--green-05); }
.sp-tag.amber { color: var(--amber); border-color: var(--amber-20); background: var(--amber-10); }

.sp-headline {
  font-family: var(--serif);
  font-size: clamp(28px, 3.5vw, 44px);
  color: var(--white);
  line-height: 1.12;
  margin-bottom: 20px;
}
.sp-headline em { font-style: italic; }
.sp-headline em.red { color: var(--red); }
.sp-headline em.blue { color: var(--blue); }
.sp-headline em.green { color: var(--green); }
.sp-headline em.amber { color: var(--amber); }

.sp-body {
  font-size: 14px;
  line-height: 1.85;
  color: var(--body);
  font-weight: 300;
  margin-bottom: 28px;
}

/* Failure table */
.fail-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--mono);
  font-size: 10px;
}
.fail-table th {
  text-align: left;
  font-weight: 600;
  color: var(--blue);
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 10px 12px;
  border-bottom: 2px solid var(--blue-20);
  font-size: 8px;
}
.fail-table td {
  padding: 12px 12px;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}
.fail-table tr:hover td { background: var(--red-10); }
.ft-id { color: var(--dim); width: 40px; }
.ft-mode { color: var(--red); font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
.ft-desc { color: var(--sub); font-family: var(--sans); line-height: 1.5; }
.ft-sev { width: 70px; }
.sev-bar { display: inline-block; height: 3px; background: var(--red); }

/* Response card */
.response-card {
  background: var(--surface);
  border: 1px solid var(--border);
  overflow: hidden;
}
.rc-header {
  padding: 10px 20px;
  background: var(--elevated);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rc-title {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 600;
  color: var(--green);
  letter-spacing: 3px;
  text-transform: uppercase;
}
.rc-live {
  font-family: var(--mono);
  font-size: 8px;
  color: var(--green);
  display: flex;
  align-items: center;
  gap: 5px;
}
.rc-live::before {
  content: '';
  width: 4px; height: 4px;
  background: var(--green);
  box-shadow: 0 0 8px var(--green);
  animation: blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.rc-body { padding: 28px; }

.rc-hed {
  font-family: var(--serif);
  font-size: 30px;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 16px;
}
.rc-hed em { color: var(--green); font-style: italic; }

.rc-text {
  font-size: 13px;
  line-height: 1.85;
  color: var(--body);
  margin-bottom: 28px;
}

.spec-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
  margin-bottom: 28px;
}
.spec-cell {
  background: var(--panel);
  padding: 16px 18px;
}
.spec-k {
  font-family: var(--mono);
  font-size: 8px;
  color: var(--muted);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.spec-v {
  font-family: var(--mono);
  font-size: 15px;
  font-weight: 600;
  color: var(--green);
}
.spec-v.red { color: var(--red); }

/* ── ARCHITECTURE ── */
.arch {
  padding: 120px 0 0;
  background: var(--surface);
}
.arch-top {
  padding: 0 48px 60px;
  max-width: 1400px;
  margin: 0 auto;
}

/* Layer data grid */
.layer-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--mono);
  font-size: 10px;
}
.layer-table thead th {
  text-align: left;
  font-weight: 600;
  color: var(--blue);
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 12px 24px;
  border-bottom: 2px solid var(--blue-20);
  border-top: 1px solid var(--border);
  font-size: 8px;
  background: var(--elevated);
}
.layer-table thead th:last-child { text-align: right; }
.layer-table tbody td {
  padding: 18px 24px;
  border-bottom: 1px solid var(--border);
}
.layer-table tbody tr { transition: background 0.15s; cursor: default; }
.layer-table tbody tr:hover { background: var(--blue-03); }
.lt-num { color: var(--dim); width: 60px; }
.lt-name { color: var(--white); font-weight: 600; letter-spacing: 2px; text-transform: uppercase; width: 200px; }
.lt-desc { color: var(--sub); font-family: var(--sans); line-height: 1.6; font-size: 12px; }
.lt-status {
  text-align: right;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  width: 130px;
}
.lt-status.green { color: var(--green); }
.lt-status.amber { color: var(--amber); }
.lt-status.blue { color: var(--blue); }

/* ── PROFILES ── */
.profiles {
  padding: 120px 0 0;
}
.profiles-top {
  padding: 0 48px 60px;
  max-width: 1400px;
  margin: 0 auto;
}
.profiles-grid {
  display: grid;
  grid-template-columns: 1fr;
  max-width: 640px;
}
@media (max-width: 900px) { .profiles-grid { grid-template-columns: 1fr; } }

.p-card {
  border-top: 1px solid var(--border);
  border-right: 1px solid var(--border);
}
.p-card:last-child { border-right: none; }

.pc-header {
  padding: 10px 24px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pc-header.inst { background: var(--green-05); }
.pc-name {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 4px;
  text-transform: uppercase;
}
.pc-header.inst .pc-name { color: var(--green); }
.pc-tier {
  font-family: var(--mono);
  font-size: 8px;
  color: var(--muted);
  letter-spacing: 2px;
}

.pc-body { padding: 28px 24px; }

.pc-tagline {
  font-family: var(--serif);
  font-style: italic;
  font-size: 19px;
  color: var(--body);
  margin-bottom: 6px;
}
.pc-for {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 32px;
}

.pc-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--mono);
  font-size: 10px;
  margin-bottom: 28px;
}
.pc-table td {
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
